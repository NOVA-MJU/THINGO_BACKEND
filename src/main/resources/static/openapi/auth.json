    "/members/validation/email": {
      "get": {
        "tags": ["Member"],
        "summary": "이메일 중복 및 도메인 검증",
        "description": "이메일이 mju.ac.kr 도메인을 가지고 있는지 확인하고, 이미 가입된 이메일인지 중복 여부를 검증합니다.",
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "example": "example@mju.ac.kr"
            },
            "description": "검사할 이메일 주소. 반드시 '@mju.ac.kr' 도메인을 포함해야 합니다."
          }
        ],
        "responses": {
          "200": {
            "description": "사용 가능한 이메일입니다.",
            "content": {
              "application/json": {
                "example": {
                  "status": "API 요청 성공",
                  "data": "사용 가능한 이메일입니다.",
                  "timestamp": "2025-07-21T15:24:53.127"
                }
              }
            }
          },
          "400": {
            "description": "유효하지 않거나 이미 존재하는 이메일",
            "content": {
              "application/json": {
                "example": {
                  "status": 400,
                  "error": "DUPLICATE_EMAIL",
                  "message": "이미 존재하는 이메일입니다."
                }
              }
            }
          }
        }
      }
    },
    "/members/recovery/email": {
      "get": {
        "tags": ["Member"],
        "summary": "비밀번호 찾기용 이메일 존재 검증",
        "description": "이메일이 '@mju.ac.kr' 도메인이고, 가입된 이메일인지 확인합니다. 존재하면 200, 존재하지 않거나 형식이 잘못되면 400을 반환합니다.",
        "parameters": [
          {
            "name": "email",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "example": "example@mju.ac.kr" },
            "description": "검사할 이메일 주소. 비어 있거나 형식이 잘못되면 400 반환."
          }
        ],
        "responses": {
          "200": {
            "description": "가입된 이메일입니다. 비밀번호 재설정 진행 가능",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "API 요청 성공" },
                    "data":   { "type": "string", "example": "가입된 이메일입니다." },
