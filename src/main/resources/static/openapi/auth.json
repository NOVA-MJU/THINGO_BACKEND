{
  "openapi": "3.0.1",
  "info": {
    "title": "MJU 인증·회원 API",
    "version": "v1.0.0",
    "description": "마이페이지, 회원 관리, 이메일 인증 기능을 위한 API 명세서입니다."
  },
  "servers": [
    { "url": "https://api.thingo.kr/api/v1" }
  ],
  "tags": [
    { "name": "Auth",  "description": "회원 로그인, 로그아웃 등 토큰 관련 API" },
    { "name": "Member",  "description": "회원 CRUD 및 인증 API" },
    { "name": "Profile", "description": "마이페이지 관련 API" },
    { "name": "Email",   "description": "회원 가입 시 이메일 인증 기능" },
    { "name": "Member Recovery",  "description": "회원 계정 복구 API" }
  ],
  
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그인",
        "description": "이메일과 비밀번호로 로그인합니다. `X-Client-Type` 헤더 값에 따라 Web/Mobile 응답 방식이 달라집니다. 헤더가 없거나 `web`이면 Web 방식으로 처리하고, `mobile`이면 Mobile 방식으로 처리합니다. 이 헤더는 응답 포맷 분기용이며 권한 판단에는 사용하지 않습니다.",
        "parameters": [
          {
            "name": "X-Client-Type",
            "in": "header",
            "required": false,
            "description": "클라이언트 타입. 값이 없거나 `web`이면 Web 응답, `mobile`이면 Mobile 응답으로 처리합니다.",
            "schema": {
              "type": "string",
              "enum": ["web", "mobile"],
              "default": "web"
            },
            "examples": {
              "web": {
                "summary": "Web",
                "value": "web"
              },
              "mobile": {
                "summary": "Mobile",
                "value": "mobile"
              }
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "format": "password" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "로그인 성공. Web은 accessToken을 body로, refreshToken을 HttpOnly Cookie로 반환합니다. Mobile은 accessToken과 refreshToken을 모두 body로 반환합니다.",
            "headers": {
              "Set-Cookie": {
                "description": "Web 로그인 응답에서만 내려갑니다. refreshToken=...; Path=/; Max-Age=1209600; HttpOnly; Secure; SameSite=None",
                "schema": { "type": "string" }
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/WebLoginResponse" },
                    { "$ref": "#/components/schemas/MobileLoginResponse" }
                  ]
                },
                "examples": {
                  "web": {
                    "summary": "Web 로그인 응답",
                    "description": "refreshToken은 body가 아니라 Set-Cookie 헤더로 전달됩니다.",
                    "value": {
                      "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI..."
                    }
                  },
                  "mobile": {
                    "summary": "Mobile 로그인 응답",
                    "description": "Mobile 요청에서는 refreshToken Cookie를 만들지 않고 body로 반환합니다.",
                    "value": {
                      "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI...",
                      "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI..."
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "인증 실패 (잘못된 자격 증명)" }
        }
      }
    },

    "/auth/logout": {
    "post": {
        "tags": ["Auth"],
        "summary": "로그아웃",
        "description": "로그아웃 처리 후 메시지를 반환합니다.",
        "security": [ { "Authorization": [] } ],
        "responses": {
          "200": {
            "description": "로그아웃 성공 메시지",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "/auth/reissue": {
      "post": {
        "tags": ["Auth"],
        "summary": "토큰 재발급",
        "description": "refreshToken을 통해 새로운 accessToken을 발급합니다. `X-Client-Type`이 없거나 `web`이면 HttpOnly Cookie의 refreshToken을 사용하고, `mobile`이면 JSON body의 refreshToken을 사용합니다. 이 헤더는 입력 포맷 분기용이며 권한 판단에는 사용하지 않습니다.",
        "parameters": [
          {
            "name": "X-Client-Type",
            "in": "header",
            "required": false,
            "description": "클라이언트 타입. 값이 없거나 `web`이면 Cookie refreshToken을 사용하고, `mobile`이면 body refreshToken을 사용합니다.",
            "schema": {
              "type": "string",
              "enum": ["web", "mobile"],
              "default": "web"
            },
            "examples": {
              "web": {
                "summary": "Web",
                "value": "web"
              },
              "mobile": {
                "summary": "Mobile",
                "value": "mobile"
              }
            }
          },
          {
            "name": "refreshToken",
            "in": "cookie",
            "required": false,
            "description": "Web reissue에서 사용하는 HttpOnly Cookie refreshToken입니다. Mobile reissue에서는 사용하지 않습니다.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "description": "Mobile reissue에서만 사용합니다. Web reissue는 body 없이 Cookie의 refreshToken을 사용합니다.",
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RefreshTokenRequest" },
              "examples": {
                "mobile": {
                  "summary": "Mobile reissue 요청",
                  "value": {
                    "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "재발급 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ReissueResponse" },
                "example": {
                  "status": "API 요청 성공",
                  "data": {
                    "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI..."
                  },
                  "timestamp": "2026-05-08T12:34:56.789"
                }
              }
            }
          },
          "400": {
            "description": "토큰 검증 실패",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status":  { "type": "integer" },
                    "error":   { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "/members": {
      "get": {
        "tags": ["Member"],
        "summary": "회원 목록 조회 (페이징)",
        "description": "관리자용: 전체 회원 정보를 페이징 처리하여 조회합니다.",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 0 } },
          { "name": "size", "in": "query", "schema": { "type": "integer", "default": 10 } }
        ],
        "responses": {
          "200": {
            "description": "회원 페이지 반환",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MemberPage" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Member"],
        "summary": "회원 가입",
        "description": "신규 회원을 등록합니다. 비밀번호는 bcrypt로 암호화되어 저장됩니다. \n\n\n 사용해야할 api는 1. 이메일 중복 검증, 2. 이메일 인증 요청 3. 이메일 인증 검토, 4. 닉네임 중복체크, 5. 최종적으로 회원가입 api 보내기\n\n이메일을 입력하고 나면 이미 가입된 이메일인지 확인한다. (이메일 중복 API로 체크) \n\n그 후 이메일 인증요청을 클릭하면 인증 번호를 메일로 부여 -> 그 후 인증 확인을 누르면 인증확인 : 인증에 대한 변수를 프론트에서 가지고 있게 할 것인지 아니면 백에서 어떻게 검증할것인지 고민 \n\n비밀번호는 조건에 맞게 작성하되 비번 2차 확인같은건 프론트에서 처리 \n\n프로필의 경우 요청받은 파일을 s3로 옮기고 그것을 cloudfront url로 프론트에게 반환 - 이때 s3로 이미지를 올리는 별도의 api요청 후 이 url을 최종 profile 이미지로 받음\n\n닉네임 중복 체크 api 생성\n\n학과는 enum 리스트 줄것 \n\n학번 검증은 하지 않되 8자리 자리수만 검증 \n\n**개인정보 동의**: privacyAgreed(boolean)는 필수이며 true여야 가입됩니다. 누락/false 시 400. 동의 정보(uuid·동의 여부·동의 시간)는 서버 로그로 기록됩니다. (응답 형식은 기존과 동일: accessToken/refreshToken)",


        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MemberCreateRequest" },
              "example": {
                "name": "김현빈",
                "email": "hbkim@mju.ac.kr",
                "password": "Pa$$w0rd!",
                "nickname": "마루명치",
                "gender": "MALE",
                "college": "AI_SOFTWARE",
                "departmentName": "DATA_SCIENCE",
                "studentNumber": "60200216",
                "profileImageUrl": "https://dxxx.cloudfront.net/member/profiles/abc123.jpg",
                "privacyAgreed": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "회원 생성 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MemberCreateResponse" },
                "example": {
                  "status": "API 요청 성공",
                  "data": {
                    "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI…",
                    "refreshToken": "eyJhbGciOiJIUzI1NiIsInR5cCI…"
                  },
                  "timestamp": "2025-07-13T15:30:12.123Z"
                }
              }
            }
          }
        }
      }
    },

    "/members/profile": {
      "post": {
        "deprecated": true,
        "tags": ["Member"],
        "summary": "프로필 이미지 업로드 -> s3 이미지 업로드로 api 변경되었습니다.",
        "description": "Multipart 이미지 업로드 → CloudFront URL 반환 (로그인 필요 없음).",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "업로드 완료",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "data":   { "type": "string", "format": "uri" },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },

