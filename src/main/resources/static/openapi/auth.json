    "/member/email/verify": {
      "post": {
        "tags": ["Email"],
        "operationId": "sendVerificationEmail",
        "summary": "이메일 인증코드 발송",
        "description": "회원가입 및 비밀번호 재설정 시 이메일로 인증코드를 발송합니다. 인증코드는 5분(TTL) 동안 유효하며, 재발급 시 최신 코드만 유효합니다. 보안상 계정 존재 여부는 응답으로 노출하지 않습니다.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" }
                },
                "required": ["email"]
              },
              "examples": {
                "default": { "value": { "email": "user@mju.ac.kr" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "인증메일 발송 완료(항상 동일 메시지 반환)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "SUCCESS" },
                    "data": { "type": "string", "example": "인증 코드가 이메일로 발송되었습니다." },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "잘못된 요청(이메일 형식 오류 등)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ERROR" },
                    "error": { "type": "string", "example": "INVALID_REQUEST" },
                    "message": { "type": "string", "example": "[MJS] 요청된 값이 잘못되었습니다." },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "/member/email/check": {
      "post": {
        "tags": ["Email"],
        "operationId": "checkVerificationCode",
        "summary": "이메일 인증코드 검증",
        "description": "이메일로 받은 인증코드를 검증합니다. 유효 시간 5분, 재발급 시 최신 코드만 허용합니다. 성공 시 서버에서 해당 코드를 즉시 소각(1회용 보장)합니다.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "code": { "type": "string", "minLength": 6, "maxLength": 6 }
                },
                "required": ["email", "code"]
              },
              "examples": {
                "default": { "value": { "email": "user@mju.ac.kr", "code": "AB12CD" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "검증 결과 반환",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "SUCCESS" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "email": { "type": "string", "format": "email" },
                        "matched": { "type": "boolean" }
                      }
                    },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                },
                "examples": {
                  "matched": {
                    "value": {
                      "status": "SUCCESS",
                      "data": { "email": "user@mju.ac.kr", "matched": true },
                      "timestamp": "2025-09-16T12:34:56Z"
                    }
                  },
                  "notMatched": {
                    "value": {
                      "status": "SUCCESS",
                      "data": { "email": "user@mju.ac.kr", "matched": false },
                      "timestamp": "2025-09-16T12:34:56Z"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "잘못된 요청(필드 누락/형식 오류 등)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ERROR" },
                    "error": { "type": "string", "example": "INVALID_REQUEST" },
                    "message": { "type": "string", "example": "[MJS] 요청된 값이 잘못되었습니다." },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "/members/recovery/verify-code": {
      "post": {
        "tags": ["Member Recovery"],
        "operationId": "verifyCodeForRecovery",
        "summary": "비밀번호 찾기 - 코드 검증 및 내부 플래그 세팅",
        "description": "비밀번호 재설정의 2단계입니다. 인증코드가 일치하면 서버 내부에 인증 성공 플래그를 15분 TTL로 저장합니다. 계정 존재 여부는 응답으로 노출하지 않으며, 코드 불일치/만료/계정 미존재는 동일한 오류 정책으로 처리합니다.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "code": { "type": "string", "minLength": 6, "maxLength": 6 }
                },
                "required": ["email", "code"]
              },
              "examples": {
                "default": { "value": { "email": "user@mju.ac.kr", "code": "AB12CD" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "코드 검증 성공(내부 플래그 세팅 완료)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "SUCCESS" },
                    "data": { "type": "string", "example": "이메일 인증이 완료되었습니다." },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "검증 실패(코드 불일치/만료/계정 미존재 등 동일 처리)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ERROR" },
                    "error": { "type": "string", "example": "INVALID_REQUEST" },
                    "message": { "type": "string", "example": "[MJS] 요청된 값이 잘못되었습니다." },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "/members/recovery/reset": {
      "post": {
        "tags": ["Member Recovery"],
        "operationId": "resetPasswordAfterVerified",
        "summary": "비밀번호 찾기 - 인증 완료 후 비밀번호 재설정",
        "description": "비밀번호 재설정의 3단계입니다. 서버 내부의 인증 성공 플래그(15분 TTL)가 존재할 때만 비밀번호를 변경하며, 변경 후 플래그는 즉시 소각합니다.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "newPassword": { "type": "string", "minLength": 8, "description": "비밀번호 정책에 맞는 새 비밀번호" }
                },
                "required": ["email", "newPassword"]
              },
              "examples": {
                "default": { "value": { "email": "user@mju.ac.kr", "newPassword": "NewStrongPwd!23" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "비밀번호 재설정 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "SUCCESS" },
                    "data": { "type": "string", "example": "비밀번호가 재설정되었습니다." },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "실패(미인증/플래그 만료/약한 비밀번호/동일 비밀번호 등)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ERROR" },
                    "error": { "type": "string", "example": "INVALID_REQUEST" },
                    "message": { "type": "string", "example": "[MJS] 요청된 값이 잘못되었습니다." },
                    "timestamp": { "type": "string", "format": "date-time" }
                  }
                },
                "examples": {
                  "weakPassword": {
                    "value": {
                      "status": "ERROR",
                      "error": "PASSWORD_IS_INVALID",
                      "message": "[MJS] 비밀번호가 잘못되었습니다",
                      "timestamp": "2025-09-16T12:34:56Z"
                    }
                  },
                  "samePassword": {
                    "value": {
                      "status": "ERROR",
                      "error": "SAME_PASSWORD_NOT_ALLOWED",
                      "message": "[MJS] 이전과 동일한 비밀번호로는 변경할 수 없습니다.",
                      "timestamp": "2025-09-16T12:34:56Z"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },

  "components": {
    "securitySchemes": {
      "Authorization": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },

    "schemas": {
      "PostItem": {
        "type": "object",
        "properties": {
          "uuid":            { "type": "string", "format": "uuid" },
          "title":           { "type": "string" },
          "previewContent":  { "type": "string", "nullable": true },
          "viewCount":       { "type": "integer" },
          "published":       { "type": "boolean" },
          "publishedAt":     { "type": "string", "format": "date-time", "nullable": true },
          "createdAt":       { "type": "string", "format": "date-time" },
          "updatedAt":       { "type": "string", "format": "date-time" },
          "likeCount":       { "type": "integer" },
          "commentCount":    { "type": "integer" },
          "author":          { "type": "string" },
          "liked":           { "type": "boolean" }
        }
      },

      "ProfileCommentItem": {
        "type": "object",
        "properties": {
          "boardUuid":            { "type": "string", "format": "uuid" },
          "boardTitle":           { "type": "string" },
          "boardPreviewContent":  { "type": "string", "nullable": true },
          "commentUuid":          { "type": "string", "format": "uuid" },
          "commentPreviewContent":{ "type": "string", "nullable": true }
        }
      },

      "MemberPage": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "content":        { "type": "array", "items": { "$ref": "#/components/schemas/MemberItem" } },
              "totalPages":     { "type": "integer" },
              "totalElements":  { "type": "integer" },
              "size":           { "type": "integer" },
              "number":         { "type": "integer" },
              "sort":           {
                "type": "object",
                "properties": {
                  "empty":    { "type": "boolean" },
                  "sorted":   { "type": "boolean" },
                  "unsorted": { "type": "boolean" }
                }
              },
              "first":           { "type": "boolean" },
              "last":            { "type": "boolean" },
              "numberOfElements":{ "type": "integer" },
              "empty":           { "type": "boolean" }
            }
          },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },

      "MemberItem": {
        "type": "object",
        "properties": {
          "uuid":          { "type": "string", "format": "uuid" },
          "name":          { "type": "string" },
          "email":         { "type": "string", "format": "email" },
          "gender":        { "type": "string", "enum": ["MALE","FEMALE","OTHER"], "nullable": true },
          "nickname":      { "type": "string", "nullable": true },
          "college":       {"type": "string", "nullable": false},
          "department":    { "type": "string", "nullable": true },
          "studentNumber": { "type": "string", "nullable": true },
          "role" : {"type": "string"}
        }
      },

      "MemberCreateRequest": {
        "type": "object",
        "properties": {
          "name":           { "type": "string" },
          "email":          { "type": "string", "format": "email" },
          "password":       { "type": "string" },
          "nickname":       { "type": "string" },
          "gender":         { "type": "string", "enum": ["MALE", "FEMALE", "OTHERS"] },
          "departmentName": { "$ref": "#/components/schemas/DepartmentName" },
          "college": { "$ref": "#/components/schemas/college" },
          "studentNumber":  { "type": "string" },
          "profileImageUrl":{ "type": "string", "format": "uri", "nullable": true },
          "privacyAgreed":  { "type": "boolean", "description": "개인정보 처리방침 동의 여부. 가입하려면 반드시 true 여야 하며, 미동의(false)나 누락 시 400을 반환합니다. 동의 정보(uuid·동의 여부·동의 시간)는 서버 로그에 기록됩니다.", "example": true }
        },
        "required": [
          "name",
          "email",
          "password",
          "nickname",
          "gender",
          "departmentName",
          "studentNumber",
          "privacyAgreed"
        ]
      },
      "MemberCreateResponse": {
        "type": "object",
        "properties": {
          "status":   { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "accessToken":  { "type": "string" },
              "refreshToken": { "type": "string" }
            }
